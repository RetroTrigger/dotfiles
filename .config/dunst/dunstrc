[global]
    monitor = 0
    follow = mouse

    ### Geometry ###
    width = (0, 360)
    height = (0, 300)
    origin = top-right
    offset = (16, 56)
    scale = 0
    notification_limit = 5

    ### Appearance ###
    frame_width = 2
    frame_color = "#3b4261"
    gap_size = 6
    corner_radius = 8
    corners = all

    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 4

    ### Icons ###
    enable_recursive_icon_lookup = true
    icon_theme = Adwaita
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    icon_corner_radius = 4

    ### Text ###
    font = Noto Sans Mono 11
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    ellipsize = middle
    show_age_threshold = 60
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = no

    ### Padding ###
    padding = 12
    horizontal_padding = 14
    text_icon_padding = 10
    separator_height = 0

    ### Behaviour ###
    sort = urgency_descending
    idle_threshold = 120
    sticky_history = yes
    history_length = 20
    always_run_script = true
    ignore_dbusclose = false
    force_xwayland = false

    ### Mouse ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

    browser = /usr/bin/xdg-open

[urgency_low]
    background = "#1a1b26"
    foreground = "#545c7e"
    frame_color = "#3b4261"
    timeout = 5

[urgency_normal]
    background = "#1a1b26"
    foreground = "#c0caf5"
    frame_color = "#7aa2f7"
    timeout = 8

[urgency_critical]
    background = "#1a1b26"
    foreground = "#f7768e"
    frame_color = "#f7768e"
    timeout = 0
